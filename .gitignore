# pyarith — .gitignore

# Python byte code
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest cache & coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Editor artefacts
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Windows
Thumbs.db
